{
  "name": "meta-ads-dashboard",
  "version": "1.0.0",
  "description": "Meta Ads Operator Dashboard — V1",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "worker": "node server/worker.js",
    "test": "node --test --test-concurrency=1 server/test/*.test.js",
    "test:xss": "bash scripts/check-xss-render-paths.sh",
    "check:deploy": "bash scripts/check-deploy-hygiene.sh",
    "db:test:seed": "NODE_ENV=test node scripts/seedE2eDb.js",
    "test:e2e": "NODE_ENV=test playwright test",
    "test:e2e:ui": "NODE_ENV=test playwright test --ui",
    "test:e2e:headed": "NODE_ENV=test playwright test --headed"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "node-fetch": "^2.7.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
