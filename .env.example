# ===========================================
# Meta Ads Dashboard — Environment Variables
# ===========================================

# Server
PORT=4000
NODE_ENV=production
# Keep true in production until staging has zero blocking CSP reports.
CSP_REPORT_ONLY=true

# Postgres
DATABASE_URL=postgresql://meta_dash:pick_a_strong_password_here@localhost:5432/meta_dashboard

# Meta Marketing API
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=act_XXXXXXXXX
META_API_VERSION=v21.0

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# Session signing and encrypted account-token storage
SESSION_SIGNING_SECRET=replace_with_a_64_char_random_hex_string
ACCOUNT_TOKEN_ENCRYPTION_SECRET=replace_with_a_64_char_random_hex_string
LEGACY_SESSION_SIGNING_SECRETS=
LEGACY_ACCOUNT_TOKEN_ENCRYPTION_SECRETS=

# Known Contact Revisit Automation
REVISIT_AUTOMATION_ENABLED=false
REVISIT_AUTOMATION_WEBHOOK_URL=
REVISIT_AUTOMATION_WEBHOOK_SIGNING_SECRET=
REVISIT_AUTOMATION_COOLDOWN_HOURS=24
REVISIT_AUTOMATION_DELAY_SECONDS=60
REVISIT_AUTOMATION_INTERVAL_MS=30000
REVISIT_AUTOMATION_MAX_ATTEMPTS=3
REVISIT_AUTOMATION_KEY_PATHS=/pricing

# Public tracker abuse controls
TRACKING_IP_RATE_LIMIT_PER_MINUTE=240
TRACKING_ACCOUNT_RATE_LIMIT_PER_MINUTE=3000
TRACKING_MAX_PAYLOAD_BYTES=20480
